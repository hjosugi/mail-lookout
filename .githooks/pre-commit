#!/bin/sh
# Auto-format staged files with oxfmt (and apply safe oxlint fixes) before
# each commit, so a forgotten `bun run format` cannot land unformatted code.
# Wired up by the package "prepare" script (git config core.hooksPath
# .githooks) on bun install.

oxfmt="./node_modules/.bin/oxfmt"
[ -x "$oxfmt" ] || oxfmt="oxfmt"
oxlint="./node_modules/.bin/oxlint"
[ -x "$oxlint" ] || oxlint="oxlint"

# Staged files only (added/copied/modified/renamed). Bail early when nothing
# is staged, so we never fall through to formatting the whole tree.
staged=$(git diff --cached --name-only --diff-filter=ACMR)
[ -n "$staged" ] || exit 0

# Format, then apply safe lint fixes, limited to the staged files. Both tools
# skip paths they don't handle (oxfmt via ignorePatterns; oxlint by type).
printf '%s\n' "$staged" | xargs "$oxfmt" --write --no-error-on-unmatched-pattern || exit 1
printf '%s\n' "$staged" | xargs "$oxlint" --fix >/dev/null 2>&1 || true

# Re-stage whatever the tools rewrote (only files already in the index).
git update-index --again
