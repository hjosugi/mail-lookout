{
  "name": "mail-lookout",
  "version": "1.0.4",
  "description": "A send-confirmation add-in for the new Outlook. It uses Smart Alerts to help prevent misdelivery.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hjosugi/mail-lookout.git"
  },
  "bugs": {
    "url": "https://github.com/hjosugi/mail-lookout/issues"
  },
  "homepage": "https://github.com/hjosugi/mail-lookout#readme",
  "keywords": [
    "outlook",
    "office-addin",
    "smart-alerts",
    "email",
    "send-confirmation"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev-certs": "office-addin-dev-certs install",
    "dev": "vite",
    "dev:emulator": "vite --open /emulator.html",
    "dev:outlook": "vite --port 3000 --strictPort",
    "build": "tsc -p tsconfig.json --noEmit && vite build && node scripts/generate-manifest.js",
    "preview": "vite preview --port 3000",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "validate": "office-addin-manifest validate manifest.xml",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major",
    "version:set": "node scripts/bump-version.js",
    "release:tag": "node scripts/release-tag.js",
    "check": "biome ci . && npm run typecheck && npm run test:coverage && npm run build && npm run validate"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.2",
    "@types/office-js": "^1.0.592",
    "@vitest/coverage-v8": "^4.1.8",
    "office-addin-dev-certs": "^2.0.9",
    "office-addin-manifest": "^2.1.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
