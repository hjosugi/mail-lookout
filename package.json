{
  "name": "mail-lookout",
  "version": "1.1.8",
  "description": "A send-confirmation add-in for the new Outlook. It uses Smart Alerts to help prevent misdelivery.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hjosugi/mail-lookout.git"
  },
  "bugs": {
    "url": "https://github.com/hjosugi/mail-lookout/issues"
  },
  "homepage": "https://github.com/hjosugi/mail-lookout#readme",
  "keywords": [
    "outlook",
    "office-addin",
    "smart-alerts",
    "email",
    "send-confirmation"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev-certs": "office-addin-dev-certs install",
    "dev": "vite",
    "dev:emulator": "vite --open /emulator.html",
    "dev:outlook": "vite --port 3000 --strictPort",
    "build": "tsc -p tsconfig.json --noEmit && vite build && bun scripts/generate-manifest.js",
    "preview": "vite preview --port 3000",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "icons": "bun scripts/make-icons.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "heartbeat": "bun scripts/heartbeat.js",
    "validate": "office-addin-manifest validate manifest.xml",
    "version:patch": "bun scripts/release-version.js patch",
    "version:minor": "bun scripts/release-version.js minor",
    "version:major": "bun scripts/release-version.js major",
    "version:set": "bun scripts/release-version.js",
    "version:bump": "bun scripts/bump-version.js",
    "release:tag": "bun scripts/release-tag.js",
    "prepare": "git config core.hooksPath .githooks",
    "check": "biome ci . && bun run typecheck && bun run test:coverage && bun run build",
    "check:publish": "bun run check && bun run validate && bun run heartbeat"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.2",
    "@types/office-js": "^1.0.592",
    "@vitest/coverage-v8": "^4.1.8",
    "office-addin-dev-certs": "^2.0.9",
    "office-addin-manifest": "^2.1.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
